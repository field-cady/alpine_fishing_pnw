          <Data name="gx_media_links">
            <value>https://mymaps.usercontent.google.com/hostedimage/m/*/3AE5a_Gy9CKYYRlKt5cFJvuOLQtFBBj6x6ef4P0rAtRvyBFUa0pvtjp3-Gf1bpXqCpz397ua1OHyX39VDOd3J9KjM6JU8IyMllTEr_wzftIlqc1dTuFXrwo7Gn_BffW-q6UKBVV7c7L7SrZCXyFoxZH9UtnmZM7mICScwTpp8mn3cFmMpdylEBQyD1xRIVwnDQH7Pm0i-VEPP?fife=s16383</value>
          </Data>
